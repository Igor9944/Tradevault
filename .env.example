# Template des variables d'environnement requises pour TradeVault Pro
# Dupliquez ce fichier en ".env" et remplissez les valeurs correspondantes.

# Clé API de messagerie Resend (Envoi des OTP et des notifications admins)
RESEND_API_KEY=

# Configuration de la base de données Supabase (Client & Serveur)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
