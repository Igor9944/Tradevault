# ⚠️ IMPORTANT SECURITY WARNING:
# Do NOT rename this .env.example file directly to .env with valid credentials inside and commit it.
# NEVER commit a ".env" file containing real passwords or secret API keys to GitHub or version control.
# Real credentials must be configured securely via environment variables in your deployment platform
# settings (such as Netlify Team Secrets / Vercel Environment Variables).
#
# To use locally: Create a copy named ".env" (which is ignored by Git in your .gitignore) and populate it.

# TradeVault Premium Config
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Resend Email Integration
RESEND_API_KEY=your_resend_api_key_here
# Optional: Set this to a verified domain email (e.g., TradeVault Pro <noreply@yourdomain.com>)
# If not specified, default is onboarding@resend.dev (only sends to your accounts' email)
RESEND_FROM_EMAIL=
